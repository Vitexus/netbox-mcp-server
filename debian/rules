#!/usr/bin/make -f

export PYBUILD_NAME=netbox_mcp_server

%:
	dh $@ --with python3 --buildsystem=pybuild

override_dh_auto_install:
	dh_auto_install
	PYTHONPATH=$$(echo debian/netbox-mcp-server/usr/lib/python3*/dist-packages) \
	    help2man --no-discard-stderr --no-info \
	    --name="read-only MCP server for NetBox infrastructure data" \
	    --version-string="$(shell dpkg-parsechangelog -S Version | sed 's/-.*//')" \
	    debian/netbox-mcp-server/usr/bin/netbox-mcp-server \
	    -o debian/netbox-mcp-server.1
	install -D -m 644 debian/netbox-mcp-server.metainfo.xml \
	    debian/netbox-mcp-server/usr/share/metainfo/cz.vitexsoftware.netbox-mcp-server.metainfo.xml
	install -D -m 644 debian/netbox-mcp-server.svg \
	    debian/netbox-mcp-server/usr/share/icons/hicolor/scalable/apps/cz.vitexsoftware.netbox-mcp-server.svg

override_dh_auto_test:
	appstreamcli validate --pedantic --no-net \
	    debian/netbox-mcp-server.metainfo.xml
